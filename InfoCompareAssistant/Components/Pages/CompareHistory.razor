@page "/compare/history"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components
@inject CompareFlowService Compare
@inject IJSRuntime JS

<PageTitle>比对历史</PageTitle>

<div class="space-y-6 fade-in h-full flex flex-col min-h-0">
    <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
            <h2 class="text-xl font-bold text-slate-800 m-0">比对历史</h2>
            <p class="text-sm text-slate-500 m-0 mt-1">按导入批次查看；明细在弹窗中打开并支持导出</p>
        </div>
        <div class="flex flex-wrap gap-2">
            <a href="/compare" class="inline-flex items-center justify-center bg-white border border-slate-200 text-slate-700 px-4 py-2.5 rounded-xl text-sm font-medium hover:bg-slate-50 no-underline">
                <i class="fa-solid fa-file-arrow-up mr-2 text-blue-600"></i>返回一键比对
            </a>
        </div>
    </div>

    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5 flex flex-wrap gap-3 items-end shrink-0">
        <div class="flex-1 min-w-[200px]">
            <label class="block text-xs font-semibold text-slate-500 mb-1.5">搜索批次</label>
            <input type="text" @bind="_keyword" @bind:event="oninput" placeholder="文件名、说明、来源单位…"
                   class="w-full bg-slate-50 border border-slate-200 text-slate-800 text-sm rounded-xl px-4 py-2.5 outline-none" />
        </div>
        <button type="button" @onclick="Query"
                class="bg-slate-800 text-white px-5 py-2.5 rounded-xl text-sm font-medium hover:bg-slate-900">
            <i class="fa-solid fa-magnifying-glass mr-2"></i>查询
        </button>
    </div>

    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden flex flex-col flex-1 min-h-0">
        <div class="overflow-x-auto overflow-y-auto flex-1">
            <table class="w-full text-left text-sm min-w-[960px]">
                <thead class="sticky top-0 bg-slate-50 text-slate-500 text-xs z-10 border-b border-slate-100">
                    <tr>
                        <th class="px-4 py-3 font-semibold">数据来源单位</th>
                        <th class="px-4 py-3 font-semibold">数据说明</th>
                        <th class="px-4 py-3 font-semibold whitespace-nowrap">导入时间</th>
                        <th class="px-4 py-3 font-semibold text-right whitespace-nowrap">触发疑点</th>
                        <th class="px-4 py-3 font-semibold text-right whitespace-nowrap">已处理</th>
                        <th class="px-4 py-3 font-semibold text-right whitespace-nowrap">操作</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50 text-slate-700">
                    @if (_batches.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="px-4 py-10 text-center text-slate-400 text-sm">暂无批次数据</td>
                        </tr>
                    }
                    @foreach (var row in _batches)
                    {
                        var b = row.Batch;
                        <tr @key="b.Id">
                            <td class="px-4 py-3 max-w-[200px]">
                                <div class="truncate" title="@(b.SourceDataUnit ?? "")">@(string.IsNullOrWhiteSpace(b.SourceDataUnit) ? "—" : b.SourceDataUnit)</div>
                            </td>
                            <td class="px-4 py-3 max-w-[280px]">
                                <div class="truncate" title="@BatchTitle(b)">@BatchTitle(b)</div>
                            </td>
                            <td class="px-4 py-3 text-slate-600 whitespace-nowrap text-xs">@b.StartedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="px-4 py-3 text-right font-mono">@b.MatchCount</td>
                            <td class="px-4 py-3 text-right font-mono">@row.ProcessedMatchCount</td>
                            <td class="px-4 py-3 text-right whitespace-nowrap">
                                <button type="button" @onclick="() => OpenDeathModal(b.Id)"
                                        class="text-blue-600 hover:underline text-xs font-medium mr-2">导入明细数据</button>
                                <button type="button" @onclick="() => OpenMatchModal(b.Id)"
                                        class="text-indigo-600 hover:underline text-xs font-medium">预警处理明细</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="px-4 py-2 border-t border-slate-100 text-xs text-slate-500 flex justify-between shrink-0">
            <span>共 @(_batchTotal) 条</span>
            <div class="flex gap-1">
                <button type="button" disabled="@(_bPage==0)" @onclick="() => { _bPage--; LoadB(); }" class="px-2 py-0.5 rounded border disabled:opacity-30">上页</button>
                <button type="button" disabled="@((_bPage+1)*_bSize >= _batchTotal)" @onclick="() => { _bPage++; LoadB(); }" class="px-2 py-0.5 rounded border disabled:opacity-30">下页</button>
            </div>
        </div>
    </div>
</div>

@if (_deathModalBatchId is int deathBid)
{
    <div class="fixed inset-0 z-[70] flex items-center justify-center p-4">
        <div class="absolute inset-0 bg-slate-900/50 backdrop-blur-sm" @onclick="CloseDeathModal"></div>
        <div class="relative w-full max-w-4xl max-h-[88vh] flex flex-col bg-white rounded-2xl shadow-2xl border border-slate-100 z-10">
            <div class="shrink-0 px-5 py-4 border-b border-slate-100 flex items-start justify-between gap-3">
                <div>
                    <h3 class="text-lg font-bold text-slate-800 m-0">导入明细数据</h3>
                    <p class="text-xs text-slate-500 m-0 mt-1">批次 #@deathBid · 共 @_deathRows.Count 条</p>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                    <button type="button" @onclick="ExportDeathAsync" disabled="@_exportBusy"
                            class="inline-flex items-center bg-emerald-600 text-white px-3 py-1.5 rounded-lg text-sm hover:bg-emerald-700 disabled:opacity-40">
                        <i class="fa-solid fa-file-export mr-2"></i>导出
                    </button>
                    <button type="button" @onclick="CloseDeathModal" class="text-slate-400 hover:text-slate-700 w-9 h-9 rounded-full flex items-center justify-center" aria-label="关闭">
                        <i class="fa-solid fa-xmark text-lg"></i>
                    </button>
                </div>
            </div>
            <div class="flex-1 min-h-0 overflow-auto p-4">
                <table class="w-full text-left text-xs border border-slate-100 rounded-lg overflow-hidden">
                    <thead class="bg-slate-50 text-slate-500">
                        <tr>
                            <th class="px-3 py-2">姓名</th>
                            <th class="px-3 py-2">身份证号</th>
                            <th class="px-3 py-2">死亡日期</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var d in _deathRows)
                        {
                            <tr>
                                <td class="px-3 py-2">@d.Name</td>
                                <td class="px-3 py-2 font-mono">@d.IdNumberNorm</td>
                                <td class="px-3 py-2">@(d.DeathDateDisplay ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@if (_matchModalBatchId is int matchBid)
{
    <div class="fixed inset-0 z-[70] flex items-center justify-center p-4">
        <div class="absolute inset-0 bg-slate-900/50 backdrop-blur-sm" @onclick="CloseMatchModal"></div>
        <div class="relative w-full max-w-5xl max-h-[88vh] flex flex-col bg-white rounded-2xl shadow-2xl border border-slate-100 z-10">
            <div class="shrink-0 px-5 py-4 border-b border-slate-100 flex items-start justify-between gap-3">
                <div>
                    <h3 class="text-lg font-bold text-slate-800 m-0">预警处理明细</h3>
                    <p class="text-xs text-slate-500 m-0 mt-1">批次 #@matchBid · 共 @_matchRows.Count 条</p>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                    <button type="button" @onclick="ExportMatchAsync" disabled="@_exportBusy"
                            class="inline-flex items-center bg-emerald-600 text-white px-3 py-1.5 rounded-lg text-sm hover:bg-emerald-700 disabled:opacity-40">
                        <i class="fa-solid fa-file-export mr-2"></i>导出
                    </button>
                    <button type="button" @onclick="CloseMatchModal" class="text-slate-400 hover:text-slate-700 w-9 h-9 rounded-full flex items-center justify-center" aria-label="关闭">
                        <i class="fa-solid fa-xmark text-lg"></i>
                    </button>
                </div>
            </div>
            <div class="flex-1 min-h-0 overflow-auto p-4">
                <table class="w-full text-left text-xs border border-slate-100 rounded-lg overflow-hidden min-w-[640px]">
                    <thead class="bg-slate-50 text-slate-500 sticky top-0">
                        <tr>
                            <th class="px-3 py-2">姓名</th>
                            <th class="px-3 py-2">身份证号</th>
                            <th class="px-3 py-2">特殊类别</th>
                            <th class="px-3 py-2">底册状态</th>
                            <th class="px-3 py-2">处理结果</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var m in _matchRows)
                        {
                            <tr>
                                <td class="px-3 py-2 font-medium">@m.Name</td>
                                <td class="px-3 py-2 font-mono">@m.IdNumberNorm</td>
                                <td class="px-3 py-2">@(m.SpecialCategory ?? "—")</td>
                                <td class="px-3 py-2">@m.RegistryStatus</td>
                                <td class="px-3 py-2">@OutcomeText(m)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private const int _bSize = 15;
    private int _bPage;
    private int _batchTotal;
    private List<CompareBatchListRow> _batches = new();
    private string _keyword = "";
    private string _qKeyword = "";

    private int? _deathModalBatchId;
    private List<DeathRecord> _deathRows = new();

    private int? _matchModalBatchId;
    private List<CompareMatch> _matchRows = new();

    private bool _exportBusy;

    protected override void OnInitialized() => LoadB();

    private void LoadB()
    {
        var (tot, list) = Compare.GetBatchHistoryPage(_bPage, _bSize, _qKeyword);
        _batchTotal = tot;
        _batches = list;
    }

    private void Query()
    {
        _qKeyword = _keyword;
        _bPage = 0;
        LoadB();
    }

    private static string BatchTitle(CompareBatch b) =>
        string.IsNullOrWhiteSpace(b.BatchNote)
            ? (string.IsNullOrWhiteSpace(b.SourceFileName) ? $"批次 #{b.Id}" : b.SourceFileName!.Trim())
            : b.BatchNote!.Trim();

    private void OpenDeathModal(int batchId)
    {
        _deathModalBatchId = batchId;
        _deathRows = Compare.GetDeathRowsForBatch(batchId);
    }

    private void CloseDeathModal()
    {
        _deathModalBatchId = null;
        _deathRows = new();
    }

    private void OpenMatchModal(int batchId)
    {
        _matchModalBatchId = batchId;
        _matchRows = Compare.GetMatches(batchId);
    }

    private void CloseMatchModal()
    {
        _matchModalBatchId = null;
        _matchRows = new();
    }

    private async Task ExportDeathAsync()
    {
        if (_deathModalBatchId is not int bid)
            return;
        _exportBusy = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            var bytes = Compare.ExportDeathImportDetails(bid);
            var b64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("icaDownloadFromBase64", $"导入明细_批次{bid}_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx",
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", b64);
        }
        finally
        {
            _exportBusy = false;
        }
    }

    private async Task ExportMatchAsync()
    {
        if (_matchModalBatchId is not int bid)
            return;
        _exportBusy = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            var bytes = Compare.ExportMatchProcessDetails(bid);
            var b64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("icaDownloadFromBase64", $"预警处理明细_批次{bid}_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx",
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", b64);
        }
        finally
        {
            _exportBusy = false;
        }
    }

    private static string OutcomeText(CompareMatch m) => m.ProcessOutcome switch
    {
        0 => "待处理",
        1 => m.ProcessNote ?? "已处理·取消身份",
        2 => m.ProcessNote ?? "已处理·死亡信息有误",
        _ => "—"
    };
}
