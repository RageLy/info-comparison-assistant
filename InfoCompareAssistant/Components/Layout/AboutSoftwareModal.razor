@rendermode InteractiveServer
@implements IDisposable
@inject AboutDialogState AboutDialog

@if (AboutDialog.IsOpen)
{
    <div class="fixed inset-0 z-[100] flex items-center justify-center p-4 overflow-y-auto overflow-x-hidden min-h-0">
        <div class="absolute inset-0 bg-slate-900/45 backdrop-blur-sm" @onclick="CloseModal"></div>
        <div class="relative my-auto w-full max-w-md rounded-2xl bg-white shadow-2xl border border-slate-200/80 overflow-hidden z-10 fade-in shrink-0">
            <div class="bg-gradient-to-br from-slate-800 via-slate-800 to-blue-900 px-6 py-5 text-white">
                <div class="flex items-start justify-between gap-3">
                    <div class="flex items-center gap-3 min-w-0">
                        <div class="w-12 h-12 rounded-xl bg-white/15 flex items-center justify-center shrink-0 ring-1 ring-white/20">
                            <img src="logo.ico" alt="" class="w-8 h-8 object-contain rounded-lg" width="32" height="32" />
                        </div>
                        <div class="min-w-0">
                            <p class="text-xs text-blue-200/90 font-medium m-0 uppercase tracking-wider">关于</p>
                            <h3 class="text-lg font-bold m-0 truncate">人员排查系统</h3>
                            <p class="text-xs text-slate-300 m-0 mt-0.5">信息比对助手</p>
                        </div>
                    </div>
                    <button type="button" @onclick="CloseModal" class="text-white/70 hover:text-white w-9 h-9 rounded-full hover:bg-white/10 flex items-center justify-center shrink-0" aria-label="关闭">
                        <i class="fa-solid fa-xmark text-lg"></i>
                    </button>
                </div>
            </div>
            <div class="px-6 py-5 space-y-0 divide-y divide-slate-100">
                <div class="flex justify-between gap-4 py-3 first:pt-0">
                    <span class="text-slate-500 text-sm shrink-0">软件版本</span>
                    <span class="text-slate-900 font-mono text-sm font-semibold text-right">@AppVersion</span>
                </div>
                <div class="flex justify-between gap-4 py-3">
                    <span class="text-slate-500 text-sm shrink-0">开发者</span>
                    <span class="text-slate-900 text-sm font-medium text-right">@DeveloperName</span>
                </div>
                <div class="flex justify-between gap-4 py-3">
                    <span class="text-slate-500 text-sm shrink-0">官方网站</span>
                    <a href="@WebsiteUrl" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-800 text-sm font-medium break-all text-right underline decoration-blue-200 underline-offset-2">@WebsiteDisplay</a>
                </div>
                <div class="flex justify-between gap-4 py-3">
                    <span class="text-slate-500 text-sm shrink-0">运行环境</span>
                    <span class="text-slate-700 text-sm text-right">.NET 8 · 单机桌面应用</span>
                </div>
                <div class="flex justify-between gap-4 py-3">
                    <span class="text-slate-500 text-sm shrink-0">版权所有</span>
                    <span class="text-slate-600 text-xs sm:text-sm text-right">© @CopyrightYear @DeveloperName · 保留所有权利</span>
                </div>
            </div>
            <div class="px-6 py-4 bg-slate-50 border-t border-slate-100 flex justify-end">
                <button type="button" @onclick="CloseModal"
                        class="bg-slate-800 hover:bg-slate-900 text-white text-sm font-medium px-5 py-2.5 rounded-xl transition-colors">
                    知道了
                </button>
            </div>
        </div>
    </div>
}

@code {
    private const string AppVersion = "1.0";
    private const string DeveloperName = "黎源";
    private const string WebsiteDisplay = "www.liyuanlife.com";
    private const string WebsiteUrl = "https://www.liyuanlife.com";
    private static int CopyrightYear => DateTime.Today.Year;

    protected override void OnInitialized() =>
        AboutDialog.Changed += OnAboutDialogChanged;

    private void OnAboutDialogChanged() => _ = InvokeAsync(StateHasChanged);

    private void CloseModal() => AboutDialog.Close();

    public void Dispose()
    {
        AboutDialog.Changed -= OnAboutDialogChanged;
    }
}
